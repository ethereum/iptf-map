{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://iptf-map.ethereum.org/schemas/use-case.json",
  "title": "IPTF Use Case Frontmatter",
  "description": "Schema for use case document frontmatter in IPTF Map",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Use case title"
    },
    "primary_domain": {
      "type": "string",
      "enum": [
        "Payments",
        "Trading",
        "Custody",
        "Funds & Assets",
        "Identity & Compliance",
        "Data & Oracles",
        "Governance",
        "Post-Quantum Threats"
      ],
      "description": "Primary business domain (matches domains/ taxonomy)"
    },
    "secondary_domain": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "null" }
      ],
      "description": "Secondary business domain(s); optional"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready"],
      "description": "Document status"
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Business priority"
    }
  },
  "additionalProperties": false
}
